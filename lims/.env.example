# LIMS Environment Variables
# Copy to .env and fill in actual values

DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-to-a-random-string
LIMS_SITE_CODE=US-LA
DATABASE_URL=postgresql://lims:lims@localhost:5432/lims
REDIS_URL=redis://localhost:6379/0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# S3/MinIO (optional for dev)
# AWS_STORAGE_BUCKET_NAME=lims-files
# AWS_S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# Email (SMTP)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
