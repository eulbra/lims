# ─────────────────────────────────────────────────────────
# NGS LIMS — Production Environment Template
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────

# ── Django Core ──
# python -c "from secrets import token_urlsafe; print(token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_<64+_characters>
DJANGO_SETTINGS_MODULE=lims.config.settings.prod
# Space-separated hostnames: "lims.example.com api.example.com"
DJANGO_ALLOWED_HOSTS=your-domain.com
DJANGO_DEBUG=False

# ── Database (PostgreSQL) ──
POSTGRES_DB=lims
POSTGRES_USER=lims
POSTGRES_PASSWORD=CHANGE_ME_<32+_characters>
DATABASE_URL=postgresql://lims:<POSTGRES_PASSWORD>@db:5432/lims

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_<24+_characters>

# ── Frontend ──
# For production, leave as /api/v1 (same-origin relative path)
# For local dev with Vite dev server, use http://localhost:8000/api/v1
VITE_API_URL=/api/v1

# ── MinIO / S3 (optional — comment out if not using) ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_<strong_password>
AWS_STORAGE_BUCKET_NAME=lims-files
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_<strong_password>

# ── JWT ──
JWT_SECRET=CHANGE_ME_<64+_characters>
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──
# Comma-separated origins: "https://lims.example.com,https://admin.example.com"
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Email (SMTP — required for notifications) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME

# ── Celery ──
CELERY_BROKER_URL=redis://:REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:REDIS_PASSWORD@redis:6379/0
